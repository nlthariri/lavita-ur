{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "setup": "composer install && npm install && cp -n .env.example .env || true && php artisan key:generate && php artisan migrate",
        "test": "php artisan test",
        "test:auth": "php artisan test --filter='AuthModuleContractTest|EmailFlowsModuleContractTest'",
        "serve": "php artisan serve",
        "queue:work": "php artisan queue:work",
        "schedule:work": "php artisan schedule:work",
        "backup:db": "bash ../scripts/backup-mysql.sh",
        "build": "vite build",
        "dev": "vite"
    },
    "devDependencies": {
        "@fontsource/inter": "^5.2.8",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.0.1",
        "geist": "^1.7.0",
        "laravel-vite-plugin": "^3.1.0",
        "postcss": "^8.5.14",
        "tailwindcss": "^3.4.19",
        "vite": "^8.0.0"
    }
}
