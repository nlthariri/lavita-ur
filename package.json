{
  "name": "lavita-ur",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:fast": "npm run lint && npm test",
    "verify:full": "npm run lint && npm test && npm run build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "bootstrap:owner": "node scripts/bootstrap-owner.mjs",
    "reports:monthly": "node scripts/send-monthly-reports.mjs",
    "retention:pseudonymize": "node scripts/pseudonymize-retention.mjs",
    "email:outbox:process": "node scripts/process-email-outbox.mjs",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production --update-env",
    "reload:pm2": "pm2 reload ecosystem.config.cjs --env production --update-env",
    "stop:pm2": "pm2 stop lavita-ur || true",
    "install:cloud86": "bash scripts/install-cloud86.sh",
    "deploy:cloud86": "bash scripts/deploy-cloud86.sh",
    "backup:db": "bash scripts/backup-mysql.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
